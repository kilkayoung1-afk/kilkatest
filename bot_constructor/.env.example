# Токен главного (родительского) бота-конструктора. Получить у @BotFather.
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ID админов через запятую (например, 111111111,222222222)
ADMIN_IDS=

# Путь к SQLite-базе (относительно корня проекта)
DATABASE_URL=sqlite+aiosqlite:///data/constructor.db

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Максимум дочерних ботов на одного пользователя (0 = без ограничений)
MAX_BOTS_PER_USER=0
