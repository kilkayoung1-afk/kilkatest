# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Comma-separated list of admin Telegram user ids
ADMIN_IDS=7119847306

# Admin contact link shown in Terms/Privacy. Accepts @username, t.me/username,
# https://t.me/username, or tg://user?id=N. Empty -> falls back to the first ADMIN_IDS.
ADMIN_CONTACT_URL=@Kilka_Young
ADMIN_CONTACT_LABEL=Написать админу

# JSON list of plans. Each plan = 1 bot of fixed size.
# Fields: id, name, stars, days, bots (always 1), mem_mb, cpu_quota, disk_mb, fsize_mb.
SUBSCRIPTION_PLANS=[{"id":"start","name":"Старт","stars":50,"days":14,"bots":1,"mem_mb":256,"cpu_quota":0.25,"disk_mb":100,"fsize_mb":25},{"id":"plus","name":"Плюс","stars":130,"days":14,"bots":1,"mem_mb":512,"cpu_quota":0.5,"disk_mb":300,"fsize_mb":50},{"id":"pro","name":"Про","stars":200,"days":14,"bots":1,"mem_mb":1024,"cpu_quota":1.0,"disk_mb":1024,"fsize_mb":100},{"id":"max","name":"Макс","stars":400,"days":14,"bots":1,"mem_mb":2048,"cpu_quota":2.0,"disk_mb":3072,"fsize_mb":200}]

# Storage paths inside the bothost container
DB_PATH=/data/bothost.sqlite3
USER_BOTS_DIR=/data/userbots

# Pre-built docker image used for user bots (built from ./userbot/)
USER_BOT_IMAGE=bothost-userbot:latest
USER_BOT_MEMORY=256m
USER_BOT_CPUS=0.5

# Hard cap on bots per user, regardless of plan
MAX_BOTS_PER_USER=50

LOG_LEVEL=INFO
