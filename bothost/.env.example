# Токен главного бота (получите у @BotFather)
BOT_TOKEN=123456:ABC-DEF...

# Telegram ID администраторов через запятую
ADMIN_IDS=7119847306

# Сколько звёзд стоит подписка
SUBSCRIPTION_STARS=50

# Сколько дней даёт одна подписка
SUBSCRIPTION_DAYS=7

# Путь до файла SQLite внутри контейнера
DB_PATH=/data/bothost.sqlite3

# Каталог для пользовательских .py файлов внутри контейнера
USER_BOTS_DIR=/data/userbots

# Имя Docker-образа, в котором запускаются пользовательские боты
USER_BOT_IMAGE=python:3.12-slim

# Лимиты для пользовательского контейнера
USER_BOT_MEMORY=256m
USER_BOT_CPUS=0.5

# Список pip-пакетов, доступных пользовательским ботам (через запятую).
# Устанавливаются один раз в общий volume.
USER_BOT_PIP_PACKAGES=aiogram==3.13.1,pyTelegramBotAPI==4.22.0,python-telegram-bot==21.6,requests==2.32.3,aiohttp==3.10.10

# Уровень логирования главного бота (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
